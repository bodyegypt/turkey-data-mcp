{
  "name": "turkey-data-mcp",
  "version": "1.0.0",
  "description": "MCP server for live Turkey data: gold & silver prices, TCMB exchange rates, fuel prices, prayer times, and Kandilli earthquake feed — powered by the free turkpidya.com public API.",
  "mcpName": "io.github.bodyegypt/turkey-data-mcp",
  "license": "MIT",
  "author": "Pidya Group <info@pidyagroup.com> (https://turkpidya.com)",
  "homepage": "https://turkpidya.com/developers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bodyegypt/turkey-data-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/bodyegypt/turkey-data-mcp/issues",
    "email": "info@pidyagroup.com"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "turkey",
    "turkiye",
    "gold-prices",
    "exchange-rates",
    "tcmb",
    "fuel-prices",
    "prayer-times",
    "earthquakes",
    "kandilli",
    "claude",
    "llm",
    "ai-tools"
  ],
  "type": "module",
  "bin": {
    "turkey-data-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "server.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
